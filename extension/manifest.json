{
    "manifest_version": 3,
    "name": "URL Shortener",
    "version": "1.0",
    "description": "Shorten the current page URL using your FastAPI backend",
    "permissions": ["tabs", "storage", "contextMenus", "notifications"],
    "host_permissions": [
        "https://url-shortner-tn0v.onrender.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
    "service_worker": "background.js"
    },
    "icons": {
    "128": "icon.png"
    }

}
